# ============================================
# 旅行助手 (Travel Assistant) 配置文件
# ============================================
# 使用方法：
#   1. 复制此文件为 .env ：  copy .env.example .env
#   2. 填入你自己的 API Key
#   3. 运行：python app.py
# ============================================

# DeepSeek / OpenAI 兼容 API 配置
# DeepSeek 注册地址：https://platform.deepseek.com/
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1

# WeatherAPI.com 配置
# 免费额度：100万次/月
# 注册地址：https://www.weatherapi.com/
WEATHER_API_KEY=your-weather-api-key-here

# Flask 运行配置
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true
